# .env.example
# Copy this file to .env and fill in the values before running the application.
# Lines starting with # are comments.
# All variables are optional at import time unless noted as [REQUIRED].

# ── Anthropic ────────────────────────────────────────────────────────────────
# [REQUIRED] Validated at startup by validate_settings() in api/config.py
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Model to use for all Claude calls
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Maximum LangGraph routing loops before the manager aborts
MAX_ROUTING_LOOPS=8

# ── Supabase ─────────────────────────────────────────────────────────────────
# [REQUIRED] Validated at startup by validate_settings()
SUPABASE_URL=https://your-project.supabase.co
# NOTE: api/config.py reads this variable under the alias SUPABASE_SERVICE_ROLE_KEY
# (via pydantic Field validation_alias). Some other files in the codebase fall back
# to SUPABASE_SERVICE_KEY (without _ROLE_) — this inconsistency exists in the
# source; set SUPABASE_SERVICE_ROLE_KEY here to satisfy api/config.py.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Neo4j ────────────────────────────────────────────────────────────────────
# Used via os.environ["NEO4J_URI"] (no fallback) in rag/hybrid_rag.py and
# research_server.py — missing values cause a KeyError at first RAG tool call.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# ── External data APIs ────────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here
NEWSAPI_KEY=your-newsapi-key-here

# ── Sentiment / Fear-Greed weights ────────────────────────────────────────────
# Weights must sum to 1.0 (validated inside sentiment_server.py at runtime)
FEAR_GREED_FINBERT_WEIGHT=0.6
FEAR_GREED_VADER_WEIGHT=0.4

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
# User ID used when no authenticated user is present
DEFAULT_USER_ID=anonymous
# Maximum seconds a POST /api/v1/analyze request may run before timeout
REQUEST_TIMEOUT_S=300

# ── Logging & CORS ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins, e.g. http://localhost:3000
ALLOWED_ORIGINS=

# ── Observability — Sentry (optional) ────────────────────────────────────────
# Error tracking via Sentry. Leave unset to disable gracefully.
# When unset, core/observability.py logs "Sentry disabled" at INFO and no-ops.
SENTRY_DSN=

# ── Observability — LangSmith (optional) ─────────────────────────────────────
# LLM / agent trace logging via LangSmith. Leave unset to disable gracefully.
# When unset, core/observability.py logs "LangSmith tracing disabled" at INFO.
LANGSMITH_API_KEY=
# Project name visible in the LangSmith UI (defaults to alpha-agent-node)
LANGSMITH_PROJECT=alpha-agent-node
